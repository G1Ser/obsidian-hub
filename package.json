{
  "name": "obsidian-hub",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "pnpm": ">=10",
    "noe": ">=21.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "bootstrap": "pnpm install",
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "build:attachment": "pnpm -C plugins/obsidian-attachment build",
    "build:emmet": "pnpm -C plugins/obsidian-emmet build",
    "build:pdf": "pnpm -C plugins/obsidian-claude-pdf build",
    "test:emmet": "pnpm -C plugins/obsidian-emmet test",
    "test:pdf": "pnpm -C plugins/obsidian-claude-pdf test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "esbuild": "0.25.12",
    "obsidian": "1.12.3",
    "prettier": "3.9.4",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
